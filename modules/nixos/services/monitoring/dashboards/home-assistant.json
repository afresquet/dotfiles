{
  "panels": [
    {
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "targets": [
        {
          "expr": "count(homeassistant_entity_available)",
          "refId": "A"
        }
      ],
      "title": "Total Entities",
      "type": "stat"
    },
    {
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        }
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "id": 2,
      "targets": [
        {
          "expr": "count(homeassistant_entity_available == 0)",
          "refId": "A"
        }
      ],
      "title": "Unavailable Entities",
      "type": "stat"
    },
    {
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "id": 3,
      "targets": [
        {
          "expr": "sum(homeassistant_light_state)",
          "refId": "A"
        }
      ],
      "title": "Lights On",
      "type": "stat"
    },
    {
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "id": 4,
      "targets": [
        {
          "expr": "sum(homeassistant_switch_state)",
          "refId": "A"
        }
      ],
      "title": "Switches On",
      "type": "stat"
    },
    {
      "fieldConfig": {
        "defaults": {
          "unit": "celsius"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "id": 5,
      "targets": [
        {
          "expr": "homeassistant_temperature_c",
          "legendFormat": "{{friendly_name}}",
          "refId": "A"
        }
      ],
      "title": "Temperatures (°C)",
      "type": "timeseries"
    },
    {
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "id": 6,
      "targets": [
        {
          "expr": "homeassistant_humidity_percent",
          "legendFormat": "{{friendly_name}}",
          "refId": "A"
        }
      ],
      "title": "Humidity (%)",
      "type": "timeseries"
    },
    {
      "fieldConfig": {
        "defaults": {
          "max": 100,
          "min": 0,
          "unit": "percent"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "id": 7,
      "targets": [
        {
          "expr": "homeassistant_battery_level_percent",
          "legendFormat": "{{friendly_name}}",
          "refId": "A"
        }
      ],
      "title": "Battery Levels (%)",
      "type": "timeseries"
    },
    {
      "fieldConfig": {
        "defaults": {
          "unit": "cpm"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "id": 8,
      "targets": [
        {
          "expr": "sum by (domain) (rate(homeassistant_state_change_total[5m])) * 60",
          "legendFormat": "{{domain}}",
          "refId": "A"
        }
